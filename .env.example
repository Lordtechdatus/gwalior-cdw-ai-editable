# Optional external Python inference service. In local development only, the
# app defaults to http://localhost:8000. Leave unset in production to use the
# clearly labelled deterministic prototype adapter.
VITE_AI_API_URL=
AI_ANALYSIS_MODE=prototype
AI_SERVICE_TOKEN=

# PostgreSQL (Vercel Postgres, Neon, or Supabase connection string).
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/gwalior_cdw

# Vercel Blob. Optional locally; required for uploads in production.
BLOB_READ_WRITE_TOKEN=

# Workspace OTP authentication. Set both values in Vercel for demo deployments.
DEMO_OTP_MODE=true
OTP=123456
AUTH_OTP_HASH_SECRET=replace-with-a-long-random-development-secret
